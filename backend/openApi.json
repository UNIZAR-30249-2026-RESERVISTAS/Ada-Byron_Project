        in: query
        name: created
        required: false
        schema:
          format: date-time
          type: string
        style: form
      - explode: false
        in: query
        name: updated
        required: false
        schema:
          format: date-time
          type: string
        style: form
      - explode: false
        in: query
        name: type
        required: false
        schema:
          type: string
        style: form
      - explode: false
        in: query
        name: title
        required: false
        schema:
