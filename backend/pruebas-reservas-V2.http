### ============================================================
### PRUEBAS RESERVAS V2 - Cobertura de nuevos invariantes/reglas
### ============================================================
### Importante:
### 1) Sustituye los placeholders por IDs reales de tu BD.
### 2) Algunos endpoints requieren sesión HTTP (JSESSIONID).
### 3) En REST Client de VS Code, tras login suele conservar cookies automáticamente.
### ============================================================

@host = http://localhost:8081
@baseUrl = {{host}}/api/reservas
@authUrl = {{host}}/api/auth
@contentType = application/json

### ---------- Datos de prueba (AJUSTAR A TU BD) ----------
@gerenteId = 2b3c463d-4497-4ba8-8f9d-ac6669983257
@estudianteId = 8124f18a-b69f-428b-b235-ddfb4979ace9
@docenteInvestigadorId = ed8c5b18-70b4-4af0-8222-748ff4cf6045
@investigadorContratadoId = 5cd6b8e3-c929-44c7-b46e-5ef7194f8e08
@tecnicoLabId = 187d7297-5672-46cc-b06a-2a4c1fe8775f

@personaNoAutorizadaId = 73f0901c-813d-47c1-bcca-76673c63a605

@espacioSalaComun = 107
@espacioAula = 002
@espacioLaboratorioDeptoA = 324
@espacioLaboratorioDeptoB = 028
@espacioDespachoDeptoA = 421
@espacioDespachoSinDepto = 414
@espacioNoReservable = 001

@fechaFutura = 2026-09-16
@horaValida = 10:00
@duracion60 = 60
@duracion90 = 90

### ============================================================
### A) AUTENTICACION Y SESION (para endpoints protegidos)
### ============================================================

### A1. Login gerente (ajustar credenciales)
# @name loginGerente
POST {{authUrl}}/login
Content-Type: {{contentType}}

{
  "email": "arturo.sanchez@example.com",
  "password": "password123"
}

### A2. Verificar sesión activa actual
GET {{authUrl}}/me

### A3. Logout (opcional)
POST {{authUrl}}/logout

### A4. Endpoint protegido SIN sesión -> debe fallar (401/403 según handler)
GET {{baseUrl}}

### ============================================================
### B) CREACION - CASOS POSITIVOS
### ============================================================

### B1. Estudiante reserva sala comun -> CONFIRMADA (REQ-F1/F6/F7 + horario)
# @name crearReservaEstudianteSalaComunOK
POST {{baseUrl}}
Content-Type: {{contentType}}

{
  "espacioIds": ["{{espacioSalaComun}}"],
  "reservadaPorId": "{{estudianteId}}",
  "tipoUso": "DOCENCIA",
  "numeroAsistentes": 5,
  "fecha": "{{fechaFutura}}",
  "horaInicio": "{{horaValida}}",
  "duracionMinutos": {{duracion60}},
  "detallesAdicionales": "Caso positivo estudiante-sala"
}

### B2. Docente-investigador reserva laboratorio de su depto -> CONFIRMADA (REQ-F4)
# @name crearReservaDocenteLabMismoDeptoOK
POST {{baseUrl}}
Content-Type: {{contentType}}

{
  "espacioIds": ["{{espacioLaboratorioDeptoA}}"],
  "reservadaPorId": "{{docenteInvestigadorId}}",
  "tipoUso": "INVESTIGACION",
  "numeroAsistentes": 6,
  "fecha": "{{fechaFutura}}",
  "horaInicio": "12:00",
  "duracionMinutos": {{duracion90}},
  "detallesAdicionales": "Caso positivo laboratorio mismo depto"
}

### B3. Reserva multi-espacio valida (INV-1 / O6)
# @name crearReservaMultiEspacioOK
POST {{baseUrl}}
Content-Type: {{contentType}}

{
  "espacioIds": ["{{espacioSalaComun}}", "{{espacioAula}}"],
  "reservadaPorId": "{{docenteInvestigadorId}}",
  "tipoUso": "DOCENCIA",
  "numeroAsistentes": 8,
  "fecha": "2026-09-21",
  "horaInicio": "11:00",
  "duracionMinutos": {{duracion60}},
  "detallesAdicionales": "Reserva multi-espacio"
}

### ============================================================
### C) CREACION - CASOS NEGATIVOS DE INVARIANTES
### ============================================================

### C1. Sin espacios -> RECHAZADA o 4xx (INV-1)
POST {{baseUrl}}
Content-Type: {{contentType}}

{
  "espacioIds": [],
  "reservadaPorId": "{{estudianteId}}",
  "tipoUso": "DOCENCIA",
  "numeroAsistentes": 5,
  "fecha": "{{fechaFutura}}",
  "horaInicio": "{{horaValida}}",
  "duracionMinutos": {{duracion60}},
  "detallesAdicionales": "Debe fallar por INV-1"
}

### C2. numeroAsistentes <= 0 -> RECHAZADA o 4xx (INV-3)
POST {{baseUrl}}
Content-Type: {{contentType}}

{
  "espacioIds": ["{{espacioSalaComun}}"],
  "reservadaPorId": "{{estudianteId}}",
  "tipoUso": "DOCENCIA",
  "numeroAsistentes": 0,
  "fecha": "{{fechaFutura}}",
  "horaInicio": "{{horaValida}}",
  "duracionMinutos": {{duracion60}},
  "detallesAdicionales": "Debe fallar por INV-3"
}

### C3. Duracion invalida (0) -> 4xx por IntervaloTemporal
POST {{baseUrl}}
Content-Type: {{contentType}}

{
  "espacioIds": ["{{espacioSalaComun}}"],
  "reservadaPorId": "{{estudianteId}}",
  "tipoUso": "DOCENCIA",
  "numeroAsistentes": 4,
  "fecha": "{{fechaFutura}}",
  "horaInicio": "{{horaValida}}",
  "duracionMinutos": 0,
  "detallesAdicionales": "Duracion invalida"
}

### C4. Fuera de horario del espacio/edificio -> RECHAZADA (REQ-C5/C6)
POST {{baseUrl}}
Content-Type: {{contentType}}

{
  "espacioIds": ["{{espacioSalaComun}}"],
  "reservadaPorId": "{{estudianteId}}",
  "tipoUso": "DOCENCIA",
  "numeroAsistentes": 3,
  "fecha": "{{fechaFutura}}",
  "horaInicio": "23:30",
  "duracionMinutos": {{duracion60}},
  "detallesAdicionales": "Debe fallar por horario"
}

### C5. Solapamiento: crear primera reserva
# @name crearReservaBaseSolape
POST {{baseUrl}}
Content-Type: {{contentType}}

{
  "espacioIds": ["{{espacioSalaComun}}"],
  "reservadaPorId": "{{estudianteId}}",
  "tipoUso": "DOCENCIA",
  "numeroAsistentes": 5,
  "fecha": "2026-09-25",
  "horaInicio": "16:00",
  "duracionMinutos": 120,
  "detallesAdicionales": "Base para prueba de solape"
}

### C6. Solapamiento sobre mismo espacio/intervalo -> RECHAZADA (REQ-F7)
POST {{baseUrl}}
Content-Type: {{contentType}}

{
  "espacioIds": ["{{espacioSalaComun}}"],
  "reservadaPorId": "{{docenteInvestigadorId}}",
  "tipoUso": "DOCENCIA",
  "numeroAsistentes": 4,
  "fecha": "2026-09-25",
  "horaInicio": "17:00",
  "duracionMinutos": 60,
  "detallesAdicionales": "Debe fallar por solape"
}

### C7. Aforo excedido -> RECHAZADA (REQ-F6)
POST {{baseUrl}}
Content-Type: {{contentType}}

{
  "espacioIds": ["{{espacioAula}}"],
  "reservadaPorId": "{{docenteInvestigadorId}}",
  "tipoUso": "DOCENCIA",
  "numeroAsistentes": 999,
  "fecha": "{{fechaFutura}}",
  "horaInicio": "09:00",
  "duracionMinutos": {{duracion60}},
  "detallesAdicionales": "Debe fallar por aforo"
}

