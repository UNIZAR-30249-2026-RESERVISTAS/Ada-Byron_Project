### Archivo de pruebas para la entidad Persona.

### Variables para las pruebas
@baseUrl = http://localhost:8081/api/personas
@contentType = application/json

### 1. Crear una persona (ESTUDIANTE)
# @name crearEstudiante
POST {{baseUrl}}
Content-Type: {{contentType}}

{
    "nombre": "Ana García",
    "email": "ana.garcia@example.com",
    "password": "password123",
    "rol": "TECNICO_LABORATORIO",
    "departamentoId": 1
}

###  Crear una persona (GERENTE)
# @name crearGerente
POST {{baseUrl}}
Content-Type: {{contentType}}

{
    "nombre": "Arturo Sánchez",
    "email": "arturo.sanchez@example.com",
    "password": "password123",
    "rol": "GERENTE",
    "departamentoId": null
}

### Guardar ID respuesta para siguientes peticiones (si tu cliente REST lo soporta, sino copiar a mano)
@idEstudiante = {{crearEstudiante.response.body.id}}


### 2. Crear una persona que requiere departamento (DOCENTE, si el depto es null FALLA)
# @name crearDocente
POST {{baseUrl}}
Content-Type: {{contentType}}

{
    "nombre": "Dr. Peter",
    "email": "peter@hospital.com",
    "password": "password1234",

    "rol": "DOCENTE_INVESTIGADOR",
    "departamentoId": null
}

### 3. Error: Email inválido
POST {{baseUrl}}
Content-Type: {{contentType}}

{
    "nombre": "Error Man",
    "email": "email-malo",
    "password": "password123",
    "rol": "ESTUDIANTE"
}

### 4. Listar todas las personas
GET {{baseUrl}}

### 5. Buscar por ID (reemplazar con un UUID real de la respuesta 1)
GET {{baseUrl}}/{{idEstudiante}}

### 6. Buscar por Email
GET {{baseUrl}}/email/house@hospital.com

### 7. Cambiar Rol de Estudiante a Conserje
PUT {{baseUrl}}/{{idEstudiante}}/rol
Content-Type: {{contentType}}

{
    "rol": "CONSERJE",
    "departamentoId": null
}

### 8. Asignar Gerente (Solo funciona si es Docente Investigador)
@idDocente = {{crearDocente.response.body.id}}
PUT {{baseUrl}}/{{idDocente}}/gerente

### 9. Quitar Gerente
DELETE {{baseUrl}}/{{idDocente}}/gerente

### 10. Eliminar Persona
DELETE {{baseUrl}}/{{idEstudiante}}

### 11. Eliminar Persona que es Docente Investigador
DELETE {{baseUrl}}/{{idDocente}}

### ====================================
### Pruebas para Departamentos
### ====================================

@departamentosUrl = http://localhost:8081/api/departamentos

### 12. Listar todos los departamentos
GET {{departamentosUrl}}

### 13. Buscar departamento por ID (Informática e Ingeniería de Sistemas)
GET {{departamentosUrl}}/1

### 14. Buscar departamento por ID (Ingeniería Electrónica y Comunicaciones)
GET {{departamentosUrl}}/2

### 15. Error: Departamento con ID inválido
GET {{departamentosUrl}}/3

### 16. Cambiar departamento de una persona (rol que requiere departamento)
PUT {{baseUrl}}/{{idDocente}}/departamento
Content-Type: {{contentType}}

{
    "departamentoId": 2
}